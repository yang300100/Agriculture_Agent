    {
      "name": "番茄早疫病",
      "symptoms": "叶片出现同心轮纹病斑，茎基部褐色凹陷",
      "prevention": "轮作，清除病残体，喷施百菌清或代森锰锌",
      "occurrence_stage": "全生育期"
    },
    {
      "name": "番茄晚疫病",
      "symptoms": "叶片出现水渍状病斑，湿度大时背面有白霉",
      "prevention": "控制湿度，发病初期喷施甲霜灵",
      "occurrence_stage": "多雨季节"
    },
    {
      "name": "番茄病毒病",
      "symptoms": "叶片黄化、皱缩、变小，植株矮化",
      "prevention": "防治蚜虫传毒，选用抗病品种",
      "occurrence_stage": "苗期至开花期"
    },
    {
      "name": "番茄青枯病",
      "symptoms": "中午萎蔫，早晚恢复，维管束变褐",
      "prevention": "轮作，嫁接栽培，土壤消毒",
      "occurrence_stage": "开花坐果期"
    }
