# ===========================================
# 模型API配置（支持不同厂商独立配置）
# ===========================================

# -------------------------------------------
# 1. LLM对话模型配置（文本生成）
# -------------------------------------------
LLM_API_KEY=111
LLM_BASE_URL=111
LLM_MODEL=111
LLM_TEMPERATURE=0.2

# -------------------------------------------
# 2. Vision视觉模型配置（图片分析）
# 如果不填写，默认使用LLM配置
# -------------------------------------------
VISION_API_KEY=
VISION_BASE_URL=
VISION_MODEL=

# -------------------------------------------
# 3. Embedding向量模型配置（知识库检索）
# 如果不填写，默认使用LLM配置
# -------------------------------------------
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_MODEL=text-embedding-3-small

# ===========================================
# 天气API配置（可选）
# 支持: openweathermap, qweather(和风天气)
# ===========================================
WEATHER_API_PROVIDER=qweather
WEATHER_API_KEY=111

# ===========================================
# RAG配置
# ===========================================
RAG_TOP_K=3
AGRICULTURE_KNOWLEDGE_DIR=agriculture_knowledge/crops

# ===========================================
# 数据存储目录
# ===========================================
DATA_STORAGE_DIR=data

# ===========================================
# 功能开关
# ===========================================
ENABLE_IMAGE_ANALYSIS=true
DEBUG_MODE=false
